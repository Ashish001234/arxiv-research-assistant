# Copy this to .env and fill in your key.
# Search mode works without any API key; only Ask mode (LLM answer generation) needs one.

# LLM provider: "groq" or "gemini"
LLM_PROVIDER=groq

# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional fallback. Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
